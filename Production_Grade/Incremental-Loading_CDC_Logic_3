{
  "watermark_file": "C:\\Pipeline\\state\\watermark.txt"
}


# Implementation of Logic
function Get-Watermark {
    param($Path)
    if (Test-Path $Path) {
        return Get-Content $Path
    }
    return "1900-01-01"
}

function Set-Watermark {
    param($Path, $Value)
    $Value | Out-File $Path -Force
}

# Usage
$lastRun = Get-Watermark $config.watermark_file

$query = "
SELECT * FROM source_table
WHERE updated_at > '$lastRun'
"

$data = Invoke-Sqlcmd -Query $query

# Process data...

# Update watermark
$newWatermark = (Get-Date).ToString("yyyy-MM-dd HH:mm:ss")
Set-Watermark $config.watermark_file $newWatermark

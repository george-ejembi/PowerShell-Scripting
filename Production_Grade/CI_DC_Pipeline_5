# GitHub Actions

name: PowerShell Data Pipeline

on:
  push:
    branches: [ "main" ]

jobs:
  run-pipeline:
    runs-on: windows-latest

    steps:
    - name: Checkout repo
      uses: actions/checkout@v3

    - name: Setup PowerShell
      uses: actions/setup-powershell@v2

    - name: Install SQL Module
      run: Install-Module SqlServer -Force -Scope CurrentUser

    - name: Run Pipeline
      run: |
        powershell.exe -ExecutionPolicy Bypass -File pipeline.ps1 -Environment "ci"
